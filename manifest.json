{
  "manifest_version": 3,
  "name": "Pearl Dupe Checker",
  "version": "1.5.4",
  "description": "Duplicate warning + open/closed hours on HubSpot contact and company records.",
  "permissions": ["cookies"],
  "host_permissions": [
    "https://app.hubspot.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.hubspot.com/contacts/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pearl Dupe Checker",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
